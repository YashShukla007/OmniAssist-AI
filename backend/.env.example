# ─────────────────────────────────────────────
#  OmniAssist AI — Backend Environment Config
# ─────────────────────────────────────────────

# Database (SQLite works out of the box; swap for PostgreSQL in production)
DATABASE_URL=sqlite:///./omniassist.db

# JWT secret — replace with a long random string before deploying
SECRET_KEY=replace-with-a-long-random-local-development-value

# ── LLM Provider ──────────────────────────────
# Choose "openrouter" (cloud API) or "ollama" (local, fully offline, no API key needed).
LLM_PROVIDER=openrouter

# ── Option A: OpenRouter (cloud) ──────────────
# Get a free API key at https://openrouter.ai
# Comma-separated list of models to try in order (falls back on rate limit).
# Example: OPENROUTER_MODELS=qwen/qwen2.5-72b-instruct,meta-llama/llama-3-8b-instruct
OPENROUTER_API_KEY=
OPENROUTER_MODELS=

# ── Option B: Ollama (local model, no API key) ─
# 1. Install Ollama:   https://ollama.com/download
# 2. Pull a model:     ollama pull llama3
#    Other options:    ollama pull mistral | phi3 | gemma2 | deepseek-r1
# 3. Change LLM_PROVIDER=ollama above and restart the backend.
#    No internet connection required once the model is downloaded.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Increase this for large models that are slow to respond (seconds)
OLLAMA_TIMEOUT_SECONDS=120

# ── File uploads ──────────────────────────────
UPLOAD_DIRECTORY=backend/uploads
